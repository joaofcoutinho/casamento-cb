# ===========================================================================
# Banco de dados — Neon.tech (PostgreSQL)
# ---------------------------------------------------------------------------
# DATABASE_URL: pooler com "pgbouncer=true" (usado em runtime)
# DIRECT_URL:   pooler sem pgbouncer (usado pelas migracoes do Prisma)
# Console do Neon: https://console.neon.tech
DATABASE_URL="postgresql://USUARIO:SENHA@ep-XXXX-pooler.REGIAO.aws.neon.tech/DB?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://USUARIO:SENHA@ep-XXXX-pooler.REGIAO.aws.neon.tech/DB?sslmode=require"

# ===========================================================================
# Painel administrativo
# ===========================================================================
ADMIN_EMAIL="seu-email@exemplo.com"
ADMIN_PASSWORD="troque-esta-senha"

# ===========================================================================
# E-mail (Resend) — opcional. Sem a chave, o envio e ignorado silenciosamente.
# ===========================================================================
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Cynthia & Benhur <noreply@seudominio.com>"
EMAIL_NOIVOS="cintia@exemplo.com"

# ===========================================================================
# Configuracoes publicas
# ===========================================================================
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_MP_LINK="https://link.mercadopago.com.br/cynthiaebenhur"

# Limite de vagas do evento (0 = sem limite)
VAGAS_LIMITE=1100
