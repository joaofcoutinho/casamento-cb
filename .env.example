# ===========================================================================
# Banco de dados — SUPABASE (PostgreSQL)
# ---------------------------------------------------------------------------
# No painel do Supabase: Project Settings > Database > Connection string.
# Use a "Connection pooling" (porta 6543) para DATABASE_URL e a conexao
# direta (porta 5432) para DIRECT_URL (usada nas migracoes do Prisma).
DATABASE_URL="postgresql://postgres.xxxxxxxx:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxxxxx:SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# Para desenvolvimento local sem Supabase, voce pode usar SQLite:
# 1) troque o provider em prisma/schema.prisma para "sqlite"
# 2) DATABASE_URL="file:./dev.db"  (e remova o bloco directUrl do schema)

# ===========================================================================
# E-mail (Resend) — opcional. Sem a chave, o envio e ignorado silenciosamente.
# ===========================================================================
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Cynthia & Benhur <noreply@seudominio.com>"
EMAIL_NOIVOS="cintia@exemplo.com"

# ===========================================================================
# Painel administrativo
# ===========================================================================
ADMIN_PASSWORD="troque-esta-senha"

# ===========================================================================
# Configuracoes publicas
# ===========================================================================
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_MP_LINK="https://link.mercadopago.com.br/cynthiaebenhur"

# Limite de vagas do evento (usado nas estatisticas do painel)
VAGAS_LIMITE=200
